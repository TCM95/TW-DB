    "page": "screen=overview_villages",
    "label": "<a href=\"#\" title=\"🎯 Import wojsk (1 klik: kopiuj, 2 klik: przejdź)\" style=\"display:inline-flex;align-items:center;gap:6px;padding:2px 8px;margin-bottom:6px;border-radius:14px;background:#f3f0e6;border:1px solid #cdbf9b;color:#5b4a2b;font-weight:700;font-size:12px;line-height:18px;text-decoration:none;\" onclick=\"try{console.log('[TW-DB][wojsko] click');var t=document.getElementById('units_table');if(!t){console.warn('[TW-DB][wojsko] #units_table not found');UI.ErrorMessage('Nie znaleziono tabeli wojsk (#units_table)',2000);return false;}if(!window.twdCopyW){console.log('[TW-DB][wojsko] step 1: copy table');var html=t.outerHTML;console.log('[TW-DB][wojsko] table html length=',html.length);try{localStorage.setItem('twd_import_wojsko',html);}catch(e){console.warn('[TW-DB][wojsko] localStorage failed',e);}try{var ta=document.createElement('textarea');ta.value=html;ta.style.position='fixed';ta.style.left='-9999px';ta.style.top='0';document.body.appendChild(ta);ta.focus();ta.select();ta.setSelectionRange(0,999999);var ok=document.execCommand('copy');document.body.removeChild(ta);console.log('[TW-DB][wojsko] execCommand copy result=',ok);if(ok){UI.SuccessMessage('Skopiowano tabelę! Kliknij ponownie, aby przejść do klinów.',2000);}else{UI.ErrorMessage('Nie udało się skopiować do schowka',2000);} }catch(err){console.error('[TW-DB][wojsko] copy error',err);UI.ErrorMessage('Błąd kopiowania',2000);}window.twdCopyW=true;}else{console.log('[TW-DB][wojsko] step 2: redirect');window.twdCopyW=false;window.location.href='https://twdatabase.online/Wedges/My';}return false;}catch(err){console.error('[TW-DB][wojsko] exception',err);UI.ErrorMessage('Błąd: '+(err&&err.message?err.message:err),2500);return false;}\"><span style=\"display:inline-flex;align-items:center;justify-content:center;width:18px;height:18px;border-radius:50%;background:#c0392b;color:#fff;font-size:12px;line-height:18px;\">🎯</span><span>Import</span></a>",
    "position": "#units_table",
    "method": "before"
  }

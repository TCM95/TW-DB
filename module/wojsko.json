(function() {
    [span_4](start_span)// Sprawdzenie czy jesteśmy na właściwej stronie[span_4](end_span)
    if (window.location.href.indexOf('screen=overview_villages') === -1) {
        return;
    }

    const targetUrl = 'https://twdatabase.online/Wedges/My';
    const table = document.querySelector('table#units_table'); 
    
    if (!table) return;

    [span_5](start_span)// Tworzenie przycisku w stylu gry[span_5](end_span)
    const btn = document.createElement('button');
    btn.type = 'button';
    btn.className = 'btn';
    btn.style.marginLeft = '10px';
    btn.style.cursor = 'pointer';
    btn.innerHTML = '<img src="https://dspl.innogamescdn.com/asset/7d1f39b6/graphic/command/attack_small.webp" style="vertical-align:middle; margin-right:5px;"> 1. Kopiuj Wojska';
    
    let isCopied = false;

    btn.onclick = function(e) {
        e.preventDefault();
        if (!isCopied) {
            try {
                [span_6](start_span)// Kopiowanie całej tabeli[span_6](end_span)
                localStorage.setItem('twd_import_data', table.outerHTML);
                btn.innerHTML = '<img src="https://dspl.innogamescdn.com/asset/7d1f39b6/graphic/command/attack_small.webp" style="vertical-align:middle; margin-right:5px;"> 2. Przejdź do Klinów';
                btn.style.backgroundColor = '#217312';
                btn.style.color = 'white';
                isCopied = true;
            } catch (err) {
                console.error('Błąd zapisu:', err);
            }
        } else {
            [span_7](start_span)// Przejście na stronę klinów[span_7](end_span)
            window.open(targetUrl, '_blank');
        }
    };

    [span_8](start_span)// Wstawienie przycisku obok nagłówka "Wioska"[span_8](end_span)
    const header = table.querySelector('th:first-child');
    if (header) {
        header.appendChild(btn);
    }
})();

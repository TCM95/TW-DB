(function() {
    const targetUrl = 'https://twdatabase.online/Wedges/My';
    [span_9](start_span)const table = document.querySelector('table#units_table'); //[span_9](end_span)
    
    if (!table) return;

    const btn = document.createElement('button');
    btn.type = 'button';
    btn.className = 'btn';
    btn.style.cssText = 'margin:10px; padding:5px 10px; cursor:pointer;';
    btn.innerHTML = '1. Kopiuj Wojska';
    
    let step = 1;
    btn.onclick = function(e) {
        e.preventDefault();
        if (step === 1) {
            localStorage.setItem('twd_import_data', table.outerHTML);
            btn.innerHTML = '2. Przejdź do Klinów';
            btn.style.backgroundColor = '#217312';
            btn.style.color = 'white';
            step = 2;
        } else {
            window.open(targetUrl, '_blank');
        }
    };
    table.parentNode.insertBefore(btn, table);
})();

    "page": "screen=overview_villages",
    "label": "<a class=\"btn\" href=\"#\" style=\"margin-left:6px;\" onclick=\"try{console.log('[TW-DB][wojsko] click');var t=document.getElementById('units_table');if(!t){UI.ErrorMessage('Nie znaleziono tabeli wojsk',2000);return false;}if(!window.twdCopyW){console.log('[TW-DB][wojsko] step 1: copy');var rows=Array.from(t.querySelectorAll('tr')).filter(function(tr){return tr.querySelector('td') && !tr.querySelector('th');});var txt=rows.map(function(tr){return (tr.innerText||tr.textContent||'').trim();}).filter(Boolean).join('\\n');txt=txt.replace(/\\r\\n/g,'\\n').trim();try{localStorage.setItem('twd_import_wojsko_text',txt);}catch(e){}navigator.clipboard.writeText(txt).then(function(){UI.SuccessMessage('Skopiowano wojska! Kliknij ponownie.',2000);window.twdCopyW=true;}).catch(function(err){console.error('[TW-DB][wojsko] copy error',err);UI.ErrorMessage('Błąd kopiowania',2000);});}else{console.log('[TW-DB][wojsko] step 2: open tab');window.twdCopyW=false;window.open('https://twdatabase.online/Wedges/My','_blank','noopener,noreferrer');}return false;}catch(err){console.error('[TW-DB][wojsko] exception',err);UI.ErrorMessage('Błąd: '+err.message,2500);return false;}\">🛡️ Import</a>",

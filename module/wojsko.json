    "page": "screen=overview_villages",
    "label": "<a class=\"btn\" href=\"#\" style=\"margin-left:6px;\" onclick=\"try{console.log('[TW-DB][wojsko] click');var t=document.getElementById('units_table');if(!t){console.warn('[TW-DB][wojsko] #units_table not found');UI.ErrorMessage('Nie znaleziono tabeli wojsk (#units_table)',2000);return false;}if(!window.twdCopyW){console.log('[TW-DB][wojsko] step 1: copy text from data rows');var rows=Array.from(t.querySelectorAll('tr')).filter(function(tr){return tr.querySelector('td') && !tr.querySelector('th');});var txt=rows.map(function(tr){return (tr.innerText||tr.textContent||'').trim();}).filter(Boolean).join('\\n');txt=txt.replace(/\\r\\n/g,'\\n').trim();console.log('[TW-DB][wojsko] rows=',rows.length,' text length=',txt.length);try{localStorage.setItem('twd_import_wojsko_text',txt);}catch(e){console.warn('[TW-DB][wojsko] localStorage failed',e);}try{var ta=document.createElement('textarea');ta.value=txt;ta.style.position='fixed';ta.style.left='-9999px';ta.style.top='0';document.body.appendChild(ta);ta.focus();ta.select();ta.setSelectionRange(0,999999);var ok=document.execCommand('copy');document.body.removeChild(ta);console.log('[TW-DB][wojsko] execCommand copy result=',ok);if(ok){UI.SuccessMessage('Skopiowano wojska! Kliknij ponownie, aby otworzyć kliny w nowej karcie.',2000);}else{UI.ErrorMessage('Nie udało się skopiować do schowka',2000);} }catch(err){console.error('[TW-DB][wojsko] copy error',err);UI.ErrorMessage('Błąd kopiowania',2000);}window.twdCopyW=true;}else{console.log('[TW-DB][wojsko] step 2: open new tab');window.twdCopyW=false;window.open('https://twdatabase.online/Wedges/My','_blank','noopener,noreferrer');}return false;}catch(err){console.error('[TW-DB][wojsko] exception',err);UI.ErrorMessage('Błąd: '+(err&&err.message?err.message:err),2500);return false;}\">🛡️ Import</a>",
    "position": "#units_table th:first-child",
    "method": "append"
  }

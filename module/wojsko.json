const TWD_Wojsko = {
    init: function() {
        const table = document.getElementById('units_table');
        if (!table || document.getElementById('twd-units-btn')) return;

        const btn = document.createElement('button');
        btn.id = 'twd-units-btn';
        btn.type = 'button';
        btn.className = 'btn';
        btn.style.margin = '10px';
        btn.innerHTML = '1. Kopiuj Wojska';

        let state = 1;
        btn.onclick = (e) => {
            e.preventDefault();
            if (state === 1) {
                localStorage.setItem('twd_import_data', table.outerHTML);
                btn.innerHTML = '2. Otwórz Kliny';
                btn.style.backgroundColor = '#217312';
                btn.style.color = 'white';
                state = 2;
            } else {
                window.open('https://twdatabase.online/Wedges/My', '_blank');
            }
        };
        table.parentNode.insertBefore(btn, table);
    }
};
TWD_Wojsko.init();

(function() {
    const targetUrl = 'https://twdatabase.online/Wedges/My';
    [span_14](start_span)const table = document.querySelector('table#units_table'); //[span_14](end_span)
    if (!table) return;

    const btn = document.createElement('button');
    btn.innerHTML = '1. Kopiuj Wojska';
    btn.className = 'btn';
    btn.style.margin = '10px';
    
    let clicked = false;
    btn.onclick = function(e) {
        e.preventDefault();
        if (!clicked) {
            localStorage.setItem('twd_import_data', table.outerHTML);
            btn.innerHTML = '2. Przejdź do Klinów';
            clicked = true;
        } else {
            window.open(targetUrl, '_blank');
        }
    };
    table.parentNode.insertBefore(btn, table);
})();

javascript:(function(){
    const table = document.getElementById('units_table');
    if(!table) return UI.ErrorMessage('Brak tabeli wojska!');

    const btn = document.createElement('button');
    btn.className = 'btn';
    btn.innerHTML = '1. Kopiuj / 2. Kliny';
    btn.style.margin = '10px';

    let clicked = false;
    btn.onclick = function(e){
        e.preventDefault();
        if(!clicked){
            localStorage.setItem('twd_import_data', table.outerHTML);
            btn.innerHTML = 'KLIKNIJ: Otwórz Kliny';
            btn.style.backgroundColor = 'green';
            btn.style.color = 'white';
            clicked = true;
        } else {
            window.open('https://twdatabase.online/Wedges/My', '_blank');
        }
    };
    table.parentNode.insertBefore(btn, table);
})();
